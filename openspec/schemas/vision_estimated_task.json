{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Vision Estimated Task",
  "type": "object",
  "properties": {
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "complexity": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          }
        },
        "required": ["name", "description", "category", "complexity"]
      }
    }
  },
  "required": ["tasks"]
}
