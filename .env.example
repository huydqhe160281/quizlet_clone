# Database (Supabase PostgreSQL)
# Runtime: pooled connection via PgBouncer (port 6543)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
# Migrations: direct connection (port 5432)
DIRECT_DATABASE_URL="postgresql://user:password@host:5432/postgres"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
# Priority order for URL resolution: AUTH_URL -> NEXTAUTH_URL -> NEXT_PUBLIC_APP_URL -> VERCEL_URL
# For Vercel Preview deployments, you can omit these to auto-fallback to VERCEL_URL
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Supabase Storage
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_MEDIA_BUCKET="flashcard-media"
# Create this bucket in Supabase Dashboard → Storage (public read for card images)

# Email (Resend) — Required for production forgot-password email delivery
# Leave empty in development: the forgot-password API returns a `devResetUrl`
# in the response instead of sending a real email. Copy the URL from the UI.
RESEND_API_KEY=""

# Optional: bundle analysis
# ANALYZE=true

# Ollama AI (required in production for AI Set Generation)
# Local dev defaults: http://localhost:11434/api + llama3 when unset
OLLAMA_BASE_URL="http://localhost:11434/api"
OLLAMA_MODEL="llama3"
# Optional: model used automatically when requested card count is high (>50)
# OLLAMA_MODEL_LARGE="gemma3:27b"

# Ollama Cloud (optional — only when using https://ollama.com)
# OLLAMA_BASE_URL="https://ollama.com/api"
# OLLAMA_MODEL="gemma3:12b"
# OLLAMA_MODEL_LARGE="gpt-oss:120b"
# OLLAMA_API_KEY="your-api-key-from-ollama.com/settings/keys"
