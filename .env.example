# Database (Supabase PostgreSQL)
# Runtime: pooled connection via PgBouncer (port 6543)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
# Migrations: direct connection (port 5432)
DIRECT_DATABASE_URL="postgresql://user:password@host:5432/postgres"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Supabase Storage
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_MEDIA_BUCKET="flashcard-media"
# Create this bucket in Supabase Dashboard → Storage (public read for card images)

# Email (Resend) — Required for production forgot-password email delivery
# Leave empty in development: the forgot-password API returns a `devResetUrl`
# in the response instead of sending a real email. Copy the URL from the UI.
RESEND_API_KEY=""

# Optional: bundle analysis
# ANALYZE=true
